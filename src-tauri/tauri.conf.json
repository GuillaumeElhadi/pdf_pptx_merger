{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pdf-merger",
  "version": "3.8.0",
  "identifier": "fr.elhadi.pdfmerger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Merger",
        "width": 960,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFENzE0M0Q1QzgwMzY3QTgKUldTb1p3UEkxVU54SFZpUk5BZk1FVlUzODJOM1A0eG51enlORFBoekw2c3FVUnprWTFydkhLNTUK",
      "endpoints": [
        "https://github.com/GuillaumeElhadi/pdf_pptx_merger/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
