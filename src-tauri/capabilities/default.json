{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/var/folders/**" },
        { "path": "/tmp/**" },
        { "path": "?:/**" }
      ]
    },
    "dialog:default",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove"
  ]
}
