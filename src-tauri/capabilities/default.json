{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "**" }]
    },
    "fs:allow-read-dir",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$TEMP/pdf_merger_*/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$TEMP/pdf_merger_*/**" }]
    },
    "fs:allow-remove",
    "updater:default",
    "process:default"
  ]
}
